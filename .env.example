# ──────────────────────────────────────────────
# Base de datos (PostgreSQL vía Prisma)
# ──────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/thesis_review

# ──────────────────────────────────────────────
# Redis (BullMQ — colas de tareas)
# ──────────────────────────────────────────────
# REDIS_URL=redis://default:password@host:6379
# REDIS_USE_TLS=true
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# ──────────────────────────────────────────────
# MinIO / S3 (Almacenamiento de documentos)
# ──────────────────────────────────────────────
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=thesis-documents
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_REGION=us-east-1

# ──────────────────────────────────────────────
# Inteligencia Artificial — LLM (DeepSeek)
# ──────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

# ──────────────────────────────────────────────
# Inteligencia Artificial — Embeddings (OpenAI)
# ──────────────────────────────────────────────
# OPENAI_API_KEY=
# EMBEDDING_MODEL=text-embedding-3-small

# ──────────────────────────────────────────────
# Plagio (Copyleaks)
# ──────────────────────────────────────────────
# COPYLEAKS_API_KEY=

# ──────────────────────────────────────────────
# ORCID OAuth 2.0 (Perfil académico de asesores)
# ──────────────────────────────────────────────
ORCID_CLIENT_ID=
ORCID_CLIENT_SECRET=
ORCID_REDIRECT_URI=http://localhost:3001/api/v1/orcid/callback
# ORCID_API_BASE=https://sandbox.orcid.org  # Sandbox para pruebas
ORCID_API_BASE=https://orcid.org             # Producción

# ──────────────────────────────────────────────
# Autenticación (JWT + NextAuth)
# ──────────────────────────────────────────────
JWT_SECRET=change-me-in-production-use-256-bits
NEXTAUTH_SECRET=change-me-in-production
NEXTAUTH_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Aplicaciones y Puertos
# ──────────────────────────────────────────────
PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3001
FRONTEND_URL=http://localhost:3000

# ──────────────────────────────────────────────
# Configuración académica
# ──────────────────────────────────────────────
MAX_GRADE=20
NEXT_PUBLIC_MAX_GRADE=20
LOW_COMPLIANCE_ALERT=65
NEXT_PUBLIC_LOW_COMPLIANCE_ALERT=65

# ──────────────────────────────────────────────
# Chatbot
# ──────────────────────────────────────────────
CHATBOT_TEMPERATURE=0.3
CHATBOT_MAX_TOKENS=1024
