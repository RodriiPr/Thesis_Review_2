{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "outDir": "./dist",
    "deleteOutDir": true,
    "assets": [
      {
        "include": "**/templates/*.{hbs,css,html}",
        "outDir": "./dist",
        "watchAssets": true
      }
    ]
  }
}
